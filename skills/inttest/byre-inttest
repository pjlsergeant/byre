#!/bin/bash
# byre-inttest -- run byre's gated integration suite on the sacrificial
# inttest VM (skill: pjlsergeant/inttest; Lima template baked at
# /etc/byre/inttest/byre-inttest.yaml).
#
# The suite must run ON the VM, not against a remote DOCKER_HOST: bind mounts
# resolve engine-side, so the tests have to execute where the engine is. This
# wrapper tars the working tree over ssh and runs `go test` there.
#
#   byre-inttest                                    # ./... -run Integration
#   byre-inttest ./internal/runner/ -run Integration -v
#   BYRE_TEST_ENGINE=podman byre-inttest            # pin the engine (VM has both)
#
# Config (env):
#   BYRE_INTTEST_USER  ssh user on the VM. No default -- Lima names the VM
#                      user after the HOST user, so pass it through:
#                      env_from_host = { BYRE_INTTEST_USER = "env:USER" }
#   BYRE_INTTEST_VM    VM address. Unset, the wrapper tries the engines'
#                      host names in order: host.docker.internal (Docker
#                      Desktop), host.containers.internal (podman) -- both
#                      carry egress grants. Native-Linux docker provides
#                      neither: set this to the host's address there (and
#                      grant that egress yourself on a firewalled box).
#   BYRE_INTTEST_PORT  ssh port (default 60022, fixed by the Lima template)
#   BYRE_INTTEST_KEY   private key (default: the machine-volume path below)
set -eu

KEY="${BYRE_INTTEST_KEY:-/home/dev/.byre-identity/inttest/byre-inttest}"
VM_USER="${BYRE_INTTEST_USER:-}"
VM_PORT="${BYRE_INTTEST_PORT:-60022}"

# An explicit BYRE_INTTEST_VM is used verbatim; otherwise take the first of
# the engines' host names that resolves here.
VM_HOST="${BYRE_INTTEST_VM:-}"
if [ -z "$VM_HOST" ]; then
  for cand in host.docker.internal host.containers.internal; do
    if getent hosts "$cand" >/dev/null 2>&1; then VM_HOST="$cand"; break; fi
  done
  if [ -z "$VM_HOST" ]; then
    echo "byre-inttest: neither host.docker.internal nor host.containers.internal resolves in this box." >&2
    echo "Native-Linux docker provides neither name: set BYRE_INTTEST_VM to the host's address" >&2
    echo "(and grant that endpoint's egress yourself on a firewalled box)." >&2
    exit 1
  fi
fi

if [ -z "$VM_USER" ]; then
  echo "byre-inttest: BYRE_INTTEST_USER is not set (the VM's ssh user)." >&2
  echo "Lima names the VM user after the HOST user; pass it through in byre.config:" >&2
  echo '  env_from_host = { BYRE_INTTEST_USER = "env:USER" }' >&2
  exit 1
fi
if [ ! -f "$KEY" ]; then
  echo "byre-inttest: no ssh key at $KEY." >&2
  echo "Once per machine -- create the VM and place the key on the shared volume:" >&2
  echo "  host:  ssh-keygen -t ed25519 -N '' -f ~/.ssh/byre-inttest       # BEFORE limactl start" >&2
  echo "  host:  limactl start --name=byre-inttest skills/inttest/byre-inttest.yaml" >&2
  echo "  host:  byre deliver ~/.ssh/byre-inttest                          # from this project" >&2
  echo "  box:   mv /inbox/byre-inttest $KEY && chmod 600 $KEY" >&2
  exit 1
fi
# The volume is dev-owned but a fresh copy may land group-readable, which ssh
# refuses; the key is ours, so keep it usable.
chmod 600 "$KEY"

SSH=(ssh -i "$KEY" -p "$VM_PORT" -o StrictHostKeyChecking=accept-new)
VM="$VM_USER@$VM_HOST"
# Per-worktree destination so concurrent sessions don't trample each other's
# synced tree (BYRE_WORKTREE is per-worktree, = BYRE_PROJECT on a plain checkout).
DEST="byre-${BYRE_WORKTREE:-default}"

# tar-over-ssh (boxes don't carry rsync); full re-extract per run -- the tree
# is small and Go's build/module caches live on the VM outside it.
tar -C /workspace -czf - --exclude .git --exclude .byre-devlog --exclude moarcode . \
  | "${SSH[@]}" "$VM" "rm -rf $DEST && mkdir -p $DEST && tar -xzf - -C $DEST"

[ $# -gt 0 ] || set -- ./... -run Integration

# Rootless podman runs the same suite several times slower than docker (crun +
# cgroupfs, a userns mapping per container, no user dbus): internal/commands
# takes ~2 min under docker and blew through go test's 10m DEFAULT under
# podman, dying `panic: test timed out after 10m0s` with the in-flight test
# only seconds old -- a clock failure, not a hang. Lift the ceiling for podman
# ONLY, so a genuine hang under docker still surfaces at the default. An
# explicitly-passed -timeout always wins.
#
# KNOWN, DEFERRED (review 2026-07-19): the match is over the joined argv, so
# `-timeout` appearing as another flag's VALUE reads as user-supplied -- e.g.
# `byre-inttest ./... -run -timeout` skips the default and podman falls back to
# go's 10m. Detecting that needs positional argv parsing; the case requires
# deliberately passing -timeout as a -run pattern, and the failure is a plain
# `panic: test timed out`, so it is not worth the shell. All normal forms
# (-timeout 5m, -timeout=5m, --timeout=1m, absent) are correct.
if [ "${BYRE_TEST_ENGINE:-}" = "podman" ]; then
  case " $* " in
    *" -timeout "*|*" -timeout="*|*" --timeout "*|*" --timeout="*) ;;
    *) set -- "$@" -timeout 40m ;;
  esac
fi

# shell-quote everything interpolated into the remote shell: the go test args
# (a -run pattern may carry |, quotes, spaces) and BYRE_TEST_ENGINE, which
# forwards so the suite can be pinned to an engine (auto prefers docker; the
# VM has both).
# BYRE_SSH_LOOP_TESTS=1: the loopback-ssh delivery test edits the VM user's
# ~/.ssh (restored on cleanup) — safe on the sacrificial VM by definition,
# which is why the wrapper sets it and a bare host-side run does not.
# BYRE_TUI_TESTS=1: the tmux TUI tier; the VM template installs tmux.
# BYRE_AGENT_TESTS forwards (not set): the agent-contract tier runs live
# agent installers — opt in per run (BYRE_AGENT_TESTS=1 byre-inttest ...);
# its scheduled home is .github/workflows/agents.yml.
"${SSH[@]}" "$VM" "cd $DEST && BYRE_DOCKER_TESTS=1 BYRE_SSH_LOOP_TESTS=1 BYRE_TUI_TESTS=1 BYRE_AGENT_TESTS=$(printf '%q' "${BYRE_AGENT_TESTS:-}") BYRE_TEST_ENGINE=$(printf '%q' "${BYRE_TEST_ENGINE:-}") go test$(printf ' %q' "$@")"
