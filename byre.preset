# byre develops itself — a Go + Claude box. PROJECT-scoped: this Go base applies
# only to this repo, never to your other projects (a new dir falls back to your
# ~/.byre/default.config, or debian:bookworm). The Claude skill is base-agnostic,
# so it works here and elsewhere.

base   = "golang:1.26-bookworm"        # the natural base for a Go project (Go, git, curl all included)
agent  = "claude"                      # Claude develops byre
skills = ["codex", "pjlsergeant/codereview", "pjlsergeant/devlog", "grok", "pjlsergeant/inttest"]
                                       # codex = the review binary (ride-along, not launched as the agent);
                                       # pjlsergeant/codereview = byre-codereview + the review-loop context;
                                       # pjlsergeant/devlog = the dev-workflow context (diary, scratch volume);
                                       #   both INSTALLED packages (moved out of the binary 2026-07-13) —
                                       #   a fresh clone fails loudly until the one-shot bootstrap in
                                       #   CLAUDE.md runs; [sources] below carries the exact commands;
                                       # grok = ride-along Grok Build CLI (logs in per project;
                                       #        grok-shared-auth is retired — ADR 0023);
                                       # pjlsergeant/inttest = byre-inttest, the gated suite on the
                                       #        sacrificial VM — installs from THIS repo (skills/README.md)

# The inttest VM's ssh user: Lima names it after the HOST user, so pass it
# through (the pjlsergeant/inttest skill's wrapper consumes it).
env_from_host = { BYRE_INTTEST_USER = "env:USER" }

# The golang images pin GOTOOLCHAIN=local; auto lets `go install` fetch a newer
# toolchain instead of hard-failing when a tool needs one.
env = { GOTOOLCHAIN = "auto" }

# goreleaser, to verify this repo's release config in-box (.goreleaser.yaml
# check / snapshot releases). Runs as root before the core block. GOPATH and
# caches point at a throwaway dir: letting root's go install touch /go leaves
# a root-owned /go/pkg behind that the dev user can't write to.
dockerfile_pre = [
  "RUN GOBIN=/usr/local/bin GOPATH=/tmp/gr GOMODCACHE=/tmp/gr/mod GOCACHE=/tmp/gr/cache GOTOOLCHAIN=auto go install github.com/goreleaser/goreleaser/v2@latest && rm -rf /tmp/gr",
]

# Acquisition hints (ADR 0029): where the installed skills above come from. Never
# auto-fetched — a missing package prints the exact install command from here.
[sources]
"pjlsergeant/codereview" = { uri = "https://raw.githubusercontent.com/pjlsergeant/pjlsergeant-byre-skills/v1.0.2/skills/codereview/skill.toml", digest = "sha256:3d0bf433dfab52ad947e125987d50b44aa47000414bbe14023bbcf80277ade86" }
"pjlsergeant/devlog" = { uri = "https://raw.githubusercontent.com/pjlsergeant/pjlsergeant-byre-skills/v1.0.0/skills/devlog/skill.toml", digest = "sha256:9ecb65b18386ceea0dc54b7bb040b42e29a9872ab8fed4f9b1f86d5562926c12" }
# Path source: inttest lives IN this repo and installs from the working tree
# (run the install from the repo root). No digest pin — the trust boundary is
# the checkout itself, and the skill's committed payload hashes still verify.
"pjlsergeant/inttest" = { uri = "skills/inttest/skill.toml" }
