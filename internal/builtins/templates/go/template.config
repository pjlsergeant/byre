# Built-in starter template: Go.
base = "golang:1.26-bookworm"

# OFFERED, not open (ADR 0020): the Go module infrastructure, one press from
# open in `byre config` -> Egress. (storage.googleapis.com deliberately absent:
# proxy.golang.org and sum.golang.org serve content directly -- verified
# 2026-07-08 -- and a blanket GCS allowance is an exfiltration-grade hole.)
egress_offered = ["proxy.golang.org", "sum.golang.org"]
