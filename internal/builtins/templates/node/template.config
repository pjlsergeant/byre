# Built-in starter template: Node.
base = "node:22-bookworm"

# Container-only node_modules. A named cache volume mounted at
# /workspace/node_modules masks the host's node_modules inside the bind-mounted
# project, so the box installs its OWN (Linux) dependencies without clobbering —
# or being clobbered by — your host's (e.g. macOS/arm64) node_modules. It's
# disposable: `byre reset` wipes it, and a fresh one starts empty + owned by the
# baked host UID (inherited from the image mount point) so `npm install` just works.
[[volumes]]
name = "node_modules"
role = "cache"
target = "/workspace/node_modules"
