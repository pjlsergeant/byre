# byre develops itself — a Go + Claude box. PROJECT-scoped: this Go base applies
# only to this repo, never to your other projects (a new dir falls back to your
# ~/.byre/default.config, or debian:bookworm). The Claude skill is base-agnostic,
# so it works here and elsewhere.

base   = "golang:1.22-bookworm"        # the natural base for a Go project (Go, git, curl all included)
agent  = "claude"                      # Claude develops byre
skills = ["codex", "devloop"]          # codex = the review binary (ride-along, not launched as the agent);
                                       # devloop = byre-codereview + the dev-workflow context
